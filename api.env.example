# Orion Collector — API Credentials
# ==================================
# Copy this file to api.env and fill in your real values.
# NEVER commit api.env to version control.
# NEVER share your API keys with anyone or paste them into public repos,
# chat messages, or forums. Treat them like passwords.

# Kalshi API Authentication
# Get your API key at: https://kalshi.com/account/api
KALSHI_ACCESS_KEY=your-kalshi-api-key-id-here
KALSHI_PRIVATE_KEY_PATH=./kalshi_private_key.pem

# Gmail Alert System (optional — only needed for email alerts)
# Requires a Gmail App Password (not your regular password).
# 1. Enable 2FA on your Google account
# 2. Go to: https://myaccount.google.com/apppasswords
# 3. Generate a new app password for "Mail"
# 4. Google shows the password with spaces (e.g. "abcd efgh ijkl mnop")
#    — remove all spaces before pasting here (e.g. "abcdefghijklmnop")
GMAIL_APP_PASSWORD=your-16-char-app-password-here
